@startuml
title Service Cloud Extension Class Diagram

left to right direction
skinparam classAttributeIconSize 0
hide empty members

package "Presentation" {
  class CaseIntakeController <<AuraEnabled>>
  class ServiceConsoleActionController <<AuraEnabled>>
}

package "Application Services" {
  class CaseIntakeService
  class CitizenVerificationService
  class CaseRoutingService
  class CaseLifecycleService
  class FeedbackAnalysisService
  class KnowledgeSuggestionService
  class IntegrationErrorService
  class MigrationReconciliationService
}

package "Data Access" {
  class ContactRepository
  class CaseRepository
  class KnowledgeRepository
  class IntegrationErrorRepository
}

package "Automation" {
  class CaseTriggerHandler
  class CaseMilestoneFlow
  class CaseAssignmentFlow
  class MDMVerificationQueueable
  class IntegrationRetryBatch
}

package "DTOs and Shared" {
  class CaseIntakeDTO
  class VerificationResultDTO
  class RoutingContextDTO
  class ServiceConstants
  class ServiceException
}

package "Salesforce Data Model" {
  class Contact <<SObject>>
  class Case <<SObject>>
  class Knowledge__kav <<SObject>>
  class ContentDocumentLink <<SObject>>
  class Integration_Error__c <<Custom Object>>
  class Migration_Batch__c <<Custom Object>>
  class Case_Routing_Rule__mdt <<Custom Metadata>>
}

