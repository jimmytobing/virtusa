@startuml
start

:Execute channel intake, verification, routing, or file operation;

if (Operation successful?) then (Yes)
  :Commit Salesforce transaction;
  stop
else (No)
  :Classify error as validation, integration, security, storage, or platform;
  if (Retryable integration error?) then (Yes)
    :Create or update Integration_Error__c;
    :Set retry count and status;
    :Place Case in Manual Review or Verification Pending;
  else (No)
    :Return user-friendly message or supervisor alert;
    :Capture exception detail for support;
  endif
  :Rollback unsafe partial changes where required;
  stop
endif

@enduml
