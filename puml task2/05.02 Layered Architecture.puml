@startuml
skinparam componentStyle rectangle

package "Presentation Layer" {
  [Experience Cloud]
  [Service Console]
  [Mobile / Web Messaging]
}

package "Channel Intake Layer" {
  [Web Case Intake]
  [Email-to-Case]
  [CTI / Voice Intake]
  [Chat / Messaging Intake]
}

package "Orchestration Layer" {
  [Flow]
  [Omni-Channel]
  [Entitlements and Milestones]
  [Knowledge Approval]
}

package "Business Service Layer" {
  [CaseIntakeService]
  [CitizenVerificationService]
  [CaseRoutingService]
  [CaseLifecycleService]
  [FeedbackAnalysisService]
  [IntegrationErrorService]
}

package "Integration Layer" {
  [Named Credentials]
  [API Gateway / Middleware]
  [External MDM]
  [Microsoft AD / Entra ID]
}

package "Persistence Layer" {
  [Contact]
  [Case]
  [Knowledge]
  [Salesforce Files]
  [Case Milestone]
  [Integration Error]
  [Migration Batch]
  [Custom Metadata]
}

[Experience Cloud] --> [Web Case Intake]
[Service Console] --> [Flow]
[Mobile / Web Messaging] --> [Chat / Messaging Intake]
[Email-to-Case] --> [CaseIntakeService]
[CTI / Voice Intake] --> [CaseIntakeService]
[Web Case Intake] --> [CaseIntakeService]
[Chat / Messaging Intake] --> [CaseIntakeService]

[CaseIntakeService] --> [CitizenVerificationService]
[CaseIntakeService] --> [CaseRoutingService]
[CaseRoutingService] --> [Omni-Channel]
[CaseLifecycleService] --> [Entitlements and Milestones]
[FeedbackAnalysisService] --> [Case]
[CitizenVerificationService] --> [Named Credentials]
[Named Credentials] --> [API Gateway / Middleware]
[API Gateway / Middleware] --> [External MDM]

[Flow] --> [CaseLifecycleService]
[Knowledge Approval] --> [Knowledge]
[CaseIntakeService] --> [Case]
[CaseIntakeService] --> [Contact]
[CaseLifecycleService] --> [Salesforce Files]
[IntegrationErrorService] --> [Integration Error]
[Custom Metadata] --> [CaseRoutingService]
[Microsoft AD / Entra ID] --> [Service Console]

@enduml
