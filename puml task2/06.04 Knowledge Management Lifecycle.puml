@startuml
start

:Search Knowledge;

if (Existing article found?) then (Yes)
  :Attach article;
  :Provide solution;
else (No)
  :Draft solution;
  :Create article draft;
  :Submit for review;
  :Supervisor reviews;

  if (Approved?) then (Yes)
    :Publish article;
  else (No)
    :Return for revision;
  endif
endif

:Reuse for similar cases;

stop
@enduml
