@startuml
left to right direction
skinparam componentStyle rectangle

actor "Branch Admin" as BranchAdmin
actor Supervisor
actor Agent

database "Case" as Case
database "Case Milestone" as Milestone
database "User" as User
database "Knowledge Article Usage" as KnowledgeUsage

package "Performance Inputs" {
  [Case Volume by Channel]
  [First Response Time]
  [Resolution Time]
  [SLA Breach Rate]
  [Reopened Case Rate]
  [Feedback Satisfaction]
  [Knowledge Reuse and Contribution]
}

package "Evaluation Views" {
  [Branch Admin Division Dashboard]
  [Supervisor Team Dashboard]
  [Agent Personal Worklist]
}

Case --> [Case Volume by Channel]
Case --> [Resolution Time]
Case --> [Reopened Case Rate]
Case --> [Feedback Satisfaction]
Milestone --> [First Response Time]
Milestone --> [SLA Breach Rate]
KnowledgeUsage --> [Knowledge Reuse and Contribution]
User --> [Case Volume by Channel]

[Case Volume by Channel] --> [Branch Admin Division Dashboard]
[First Response Time] --> [Branch Admin Division Dashboard]
[Resolution Time] --> [Branch Admin Division Dashboard]
[SLA Breach Rate] --> [Branch Admin Division Dashboard]
[Feedback Satisfaction] --> [Branch Admin Division Dashboard]

[Case Volume by Channel] --> [Supervisor Team Dashboard]
[Reopened Case Rate] --> [Supervisor Team Dashboard]
[Knowledge Reuse and Contribution] --> [Supervisor Team Dashboard]

[Agent Personal Worklist] --> Agent
BranchAdmin --> [Branch Admin Division Dashboard]
Supervisor --> [Supervisor Team Dashboard]

@enduml
