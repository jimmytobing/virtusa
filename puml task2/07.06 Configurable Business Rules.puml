@startuml
left to right direction
skinparam linetype ortho

entity Case_Routing_Rule__mdt {
  DeveloperName
  Record_Type__c
  Channel__c
  Division__c
  Skill__c
  Language__c
  Priority__c
  Active__c
}

entity SLA_Policy__mdt {
  DeveloperName
  Record_Type__c
  Priority__c
  First_Response_Hours__c
  Resolution_Hours__c
  Follow_Up_Hours__c
  Active__c
}

entity Feedback_Category__mdt {
  DeveloperName
  Service_Category__c
  Improvement_Area__c
  Severity__c
  Active__c
}

entity Integration_Error_Message__mdt {
  DeveloperName
  Service_Name__c
  Error_Code__c
  User_Message__c
  Retryable__c
  Active__c
}

Case_Routing_Rule__mdt ..> SLA_Policy__mdt : applies SLA
Feedback_Category__mdt ..> SLA_Policy__mdt : informs priority
Integration_Error_Message__mdt ..> Case_Routing_Rule__mdt : fallback queue

@enduml
