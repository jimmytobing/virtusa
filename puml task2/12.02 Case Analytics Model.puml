@startuml
left to right direction

database "Case" as Case
database "Contact" as Contact
database "User" as User
database "Case Milestone" as Milestone
database "Knowledge Article Usage" as KnowledgeUsage

package "Analytics Dataset" {
  [Case Volume Metrics]
  [Agent Productivity Metrics]
  [SLA Metrics]
  [Feedback Satisfaction Metrics]
  [Channel Effectiveness Metrics]
  [Knowledge Reuse Metrics]
  [Backlog Aging Metrics]
}

package "Dashboards" {
  [Branch Admin Dashboard]
  [Supervisor Dashboard]
  [Agent Dashboard]
}

Case --> [Case Volume Metrics]
Case --> [Channel Effectiveness Metrics]
User --> [Agent Productivity Metrics]
Milestone --> [SLA Metrics]
Case --> [Feedback Satisfaction Metrics]
Contact --> [Case Volume Metrics]
KnowledgeUsage --> [Knowledge Reuse Metrics]
Case --> [Backlog Aging Metrics]

[Case Volume Metrics] --> [Branch Admin Dashboard]
[Channel Effectiveness Metrics] --> [Branch Admin Dashboard]
[Backlog Aging Metrics] --> [Branch Admin Dashboard]
[Agent Productivity Metrics] --> [Supervisor Dashboard]
[SLA Metrics] --> [Supervisor Dashboard]
[Feedback Satisfaction Metrics] --> [Branch Admin Dashboard]
[Knowledge Reuse Metrics] --> [Supervisor Dashboard]
[Case Volume Metrics] --> [Agent Dashboard]

@enduml
