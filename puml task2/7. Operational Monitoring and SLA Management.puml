@startuml
left to right direction

package "Salesforce Case Operations" {
  [Case Created]
  [Case Assigned]
  [Case In Progress]
  [Case Escalated]
  [Case Pending Citizen]
  [Case Closed]
}

package "SLA Monitoring" {
  [Entitlement Process]
  [Milestones]
  [SLA Breach Alerts]
  [Escalation Rules]
}

package "Management Dashboards" {
  [Agent Performance Dashboard]
  [Channel Volume Dashboard]
  [SLA Compliance Dashboard]
  [Citizen Satisfaction Dashboard]
  [Backlog and Aging Dashboard]
  [Integration Error Dashboard]
}

package "Integration Monitoring" {
  [MDM Verification Errors]
  [Channel Intake Errors]
  [Retry Queue]
}

[Case Created] --> [Entitlement Process]
[Case Assigned] --> [Milestones]
[Case Pending Citizen] --> [Milestones]
[Milestones] --> [SLA Breach Alerts]
[SLA Breach Alerts] --> [Escalation Rules]

[Case Created] --> [Channel Volume Dashboard]
[Case Closed] --> [Agent Performance Dashboard]
[Milestones] --> [SLA Compliance Dashboard]
[Case Closed] --> [Citizen Satisfaction Dashboard]
[Case Assigned] --> [Backlog and Aging Dashboard]
[Case Escalated] --> [Backlog and Aging Dashboard]
[MDM Verification Errors] --> [Retry Queue]
[Channel Intake Errors] --> [Retry Queue]
[Retry Queue] --> [Integration Error Dashboard]

@enduml
