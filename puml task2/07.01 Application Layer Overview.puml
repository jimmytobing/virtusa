@startuml
skinparam componentStyle rectangle

package "Presentation Layer" {
  [Experience Cloud Case Form]
  [Service Console]
  [Supervisor Console]
  [Dashboards]
}

package "Channel Services" {
  [Email-to-Case]
  [CTI / Voice]
  [Digital Engagement]
  [Web/API Intake]
}

package "Application Layer" {
  [Flow Automation]
  [Omni-Channel]
  [Entitlements and Milestones]
  [Knowledge Approval]
}

package "Business Services" {
  [CaseIntakeService]
  [CitizenVerificationService]
  [CaseRoutingService]
  [CaseLifecycleService]
  [FeedbackAnalysisService]
  [IntegrationErrorService]
}

database "Salesforce Data" {
  [Contact]
  [Case]
  [Knowledge]
  [Files]
  [Case Milestone]
  [Integration Error]
}

[Experience Cloud Case Form] --> [Web/API Intake]
[Service Console] --> [Flow Automation]
[Supervisor Console] --> [Flow Automation]
[Email-to-Case] --> [CaseIntakeService]
[CTI / Voice] --> [CaseIntakeService]
[Digital Engagement] --> [CaseIntakeService]
[Web/API Intake] --> [CaseIntakeService]
[CaseIntakeService] --> [CitizenVerificationService]
[CaseIntakeService] --> [CaseRoutingService]
[CaseRoutingService] --> [Omni-Channel]
[CaseLifecycleService] --> [Entitlements and Milestones]
[Flow Automation] --> [CaseLifecycleService]
[FeedbackAnalysisService] --> [Case]
[IntegrationErrorService] --> [Integration Error]
[CaseIntakeService] --> [Contact]
[CaseIntakeService] --> [Case]
[Service Console] --> [Knowledge]
[Service Console] --> [Files]
[Dashboards] --> [Case]
[Dashboards] --> [Case Milestone]

@enduml
