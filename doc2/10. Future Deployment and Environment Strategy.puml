@startuml
skinparam componentStyle rectangle

package "Developer Environment" {

    node "Developer Laptop" {

        artifact "VS Code"

        artifact "Salesforce CLI"

        artifact "Git Client"

    }

}

cloud "GitHub Repository" as Git

package "CI/CD" {

    rectangle "GitHub Actions"

    rectangle "PMD Scan"

    rectangle "Apex Unit Test"

    rectangle "Validation Deployment"

}

package "Salesforce Environments" {

    node "Scratch Org"

    node "Developer Sandbox"

    node "Integration Sandbox"

    node "UAT Sandbox"

    node "Production"

}

"Git Client" --> Git : Push Source

Git --> "GitHub Actions"

"GitHub Actions" --> "PMD Scan"

"PMD Scan" --> "Apex Unit Test"

"Apex Unit Test" --> "Validation Deployment"

"Validation Deployment" --> "Developer Sandbox"

"Developer Sandbox" --> "Integration Sandbox"

"Integration Sandbox" --> "UAT Sandbox"

"UAT Sandbox" --> Production

"VS Code" --> "Scratch Org"

"Salesforce CLI" --> "Scratch Org"

@enduml
