@startuml

participant Citizen

participant LWC

participant Flow

participant GrantApplicationService

participant ContactMatchingService

participant GrantSupportOptionService

participant GrantDisbursementService

database Salesforce

Citizen -> LWC : Submit Application

LWC -> GrantApplicationService : submitApplication

GrantApplicationService -> GrantSupportOptionService : Get active option

GrantSupportOptionService --> GrantApplicationService

GrantApplicationService -> ContactMatchingService : Upsert applicant by phone

ContactMatchingService --> GrantApplicationService

GrantApplicationService --> Salesforce : Save Grant Application

GrantApplicationService -> GrantDisbursementService : Recalculate schedule

GrantDisbursementService --> Salesforce : Save Disbursements

Flow -> Salesforce : Set lifecycle fields / create tasks

GrantDisbursementService --> GrantApplicationService

GrantApplicationService --> LWC

LWC --> Citizen : Success

@enduml
