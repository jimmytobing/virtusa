@startuml

skinparam componentStyle rectangle
skinparam component {
    BackgroundColor<<future>> #FFF4E6
    BorderColor<<future>> #C47F36
    BorderStyle<<future>> dashed
}
skinparam cloud {
    BackgroundColor<<future>> #FFF4E6
    BorderColor<<future>> #C47F36
    BorderStyle<<future>> dashed
}

actor Citizen
actor "Branch Admin" as BranchAdmin
actor Supervisor
actor Agent

cloud "Microsoft Azure AD\n(Future Internal SSO)" as AAD <<future>>

package "Salesforce Experience Cloud" {

    [Experience Site]

    [Lightning Web Components]

}

package "Salesforce Service Channels\n(Future Case Intake)" <<future>> {

    component "Web Case Intake" as WebCaseFuture <<future>>

    component "Phone Case Intake" as PhoneCaseFuture <<future>>

    component "Chat / Mobile Case Intake" as ChatMobileCaseFuture <<future>>

    component "Email Case Intake" as EmailCaseFuture <<future>>

    component "Omni-Channel Routing" as OmniChannelFuture <<future>>

}

package "Salesforce Service Operations\n(Future Internal Users)" <<future>> {

    component "Service Console" as ServiceConsoleFuture <<future>>

    component "Reports and Dashboards" as ReportsFuture <<future>>

}

package "Salesforce Platform" {

    [Flow]

    [Apex Service Layer]

    [Trigger Framework]

    [Custom Metadata]

}

database "Salesforce Data" {

    [Contact]

    [Grant Application]

    [Grant Disbursement]

    [Integration Error]

    component "Case" as CaseFuture <<future>>

    component "Knowledge" as KnowledgeFuture <<future>>

    component "Files" as FilesFuture <<future>>

    component "Service Division" as ServiceDivisionFuture <<future>>

}

cloud "API Gateway" as ApiGateway <<future>> {

}

cloud "Master Data Management" as MDM <<future>> {

}

Citizen --> [Experience Site]

Citizen ..> WebCaseFuture : future web enquiry / feedback
Citizen ..> PhoneCaseFuture : future call
Citizen ..> ChatMobileCaseFuture : future real-time assistance
Citizen ..> EmailCaseFuture : future email

BranchAdmin ..> ReportsFuture : future oversight
Supervisor ..> ServiceConsoleFuture : future supervision
Agent ..> ServiceConsoleFuture : future case handling

[Experience Site] --> [Lightning Web Components]

[Lightning Web Components] --> [Flow]

WebCaseFuture ..> OmniChannelFuture : future assignment
PhoneCaseFuture ..> OmniChannelFuture : future assignment
ChatMobileCaseFuture ..> OmniChannelFuture : future assignment
EmailCaseFuture ..> OmniChannelFuture : future assignment
OmniChannelFuture ..> ServiceConsoleFuture
ServiceConsoleFuture ..> CaseFuture
ServiceConsoleFuture ..> KnowledgeFuture
ServiceConsoleFuture ..> FilesFuture
ReportsFuture ..> CaseFuture

[Flow] --> [Apex Service Layer]

[Apex Service Layer] --> [Trigger Framework]

[Apex Service Layer] --> [Custom Metadata]

[Apex Service Layer] --> [Contact]

[Apex Service Layer] --> [Grant Application]

[Apex Service Layer] --> [Grant Disbursement]

[Apex Service Layer] --> [Integration Error]

[Apex Service Layer] ..> CaseFuture : future support case

[Apex Service Layer] ..> KnowledgeFuture : future support content

[Apex Service Layer] ..> FilesFuture : future document upload

[Apex Service Layer] ..> ServiceDivisionFuture : future division security

[Apex Service Layer] ..> ApiGateway : future integration

ApiGateway ..> MDM

AAD ..> ServiceConsoleFuture : future internal SSO

legend right
  |= Style |= Meaning |
  |<#FFF4E6> Dashed border | Future enhancement / not active in current implementation |
endlegend

@enduml
