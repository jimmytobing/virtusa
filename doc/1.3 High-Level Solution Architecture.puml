@startuml

skinparam componentStyle rectangle
skinparam component {
    BackgroundColor<<future>> #FFF4E6
    BorderColor<<future>> #C47F36
    BorderStyle<<future>> dashed
}
skinparam cloud {
    BackgroundColor<<future>> #FFF4E6
    BorderColor<<future>> #C47F36
    BorderStyle<<future>> dashed
}

actor Citizen

cloud "Microsoft Azure AD\n(Optional Future SSO)" as AAD <<future>>

package "Salesforce Experience Cloud" {

    [Experience Site]

    [Lightning Web Components]

}

package "Salesforce Platform" {

    [Flow]

    [Apex Service Layer]

    [Trigger Framework]

    [Custom Metadata]

}

database "Salesforce Data" {

    [Contact]

    [Grant Application]

    [Grant Disbursement]

    [Integration Error]

    component "Case" as CaseFuture <<future>>

    component "Knowledge" as KnowledgeFuture <<future>>

    component "Files" as FilesFuture <<future>>

}

cloud "API Gateway" as ApiGateway <<future>> {

}

cloud "Master Data Management" as MDM <<future>> {

}

Citizen --> [Experience Site]

[Experience Site] --> [Lightning Web Components]

[Lightning Web Components] --> [Apex Service Layer]

[Flow] --> [Apex Service Layer]

[Apex Service Layer] --> [Trigger Framework]

[Apex Service Layer] --> [Custom Metadata]

[Apex Service Layer] --> [Contact]

[Apex Service Layer] --> [Grant Application]

[Apex Service Layer] --> [Grant Disbursement]

[Apex Service Layer] --> [Integration Error]

[Apex Service Layer] ..> CaseFuture : future support case

[Apex Service Layer] ..> KnowledgeFuture : future support content

[Apex Service Layer] ..> FilesFuture : future document upload

[Apex Service Layer] ..> ApiGateway : future integration

ApiGateway ..> MDM

AAD ..> [Experience Site] : future SSO

legend right
  |= Style |= Meaning |
  |<#FFF4E6> Dashed border | Future enhancement / not active in current implementation |
endlegend

@enduml
